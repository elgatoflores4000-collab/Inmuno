flowchart TD
    A["ALÉRGENO (1º contacto)"] --> B["Entrada por mucosa\nrespiratoria, digestiva o piel"]

    B --> C["Célula dendrítica (APC)\ncaptura y procesa alérgeno"]
    C --> D["Migra a ganglio linfático\npresenta en MHC-II"]

    D --> E["Linfocito T CD4+ naïve\nreconoce Ag + MHC-II"]

    subgraph Th2_diff ["Diferenciación a Th2 (paralelo)"]
        E --> F1["Ausencia de IL-12\n(no señal de peligro)"]
        E --> F2["Alarminas del epitelio\n(IL-25, IL-33, TSLP)"]
        E --> F3["Activación directa de\nILC2 por alarminas"]
    end

    F1 --> G["Diferenciación a Th2\n(GATA-3, STAT6)"]
    F2 --> G
    F3 --> H["ILC2 secreta\nIL-5, IL-13 (respuesta innata)"]

    G --> I["Th2 secreta IL-4, IL-5, IL-13, IL-9"]

    subgraph Acciones_Th2 ["Acciones simultáneas de Th2"]
        I --> J1["Sobre linfocito B:\nIL-4, IL-13 + CD40L-CD40\n→ cambio de isotipo a IgE"]
        I --> J2["Sobre eosinófilos:\nIL-5 → activación y\nreclutamiento"]
        I --> J3["Sobre epitelio:\nIL-13 → moco"]
    end

    J1 --> K["Célula plasmática secreta\nIgE específica"]
    K --> L["IgE se une a FcεRI\nen mastocitos y basófilos\n(SENSIBILIZACIÓN)"]

    L --> M["Segundo contacto con el\nMISMO ALÉRGENO"]

    M --> N["Entrecruzamiento de IgE\ny agregación de FcεRI"]

    subgraph Senializacion ["Señalización intracelular en mastocito/basófilo"]
        N --> O1["Activación de Lyn y Fyn"]
        O1 --> O2["Fosforilación de ITAM\nen cadenas β y γ"]
        O2 --> O3["Reclutamiento y activación\n de Syk"]
        O3 --> O4["Activación de PLCγ"]
        O4 --> O5["IP₃ + DAG\n→ IP₃ libera Ca²⁺ del RE\n→ DAG activa PKC"]
    end

    subgraph Mediadores ["Liberación y síntesis de mediadores (simultáneo)"]
        O5 --> P1["DESGRANULACIÓN\n(segundos-minutos)\nHistamina, proteasas,\nheparina, ECF, NCF"]
        O5 --> P2["Síntesis de novo\n(ácido araquidónico)\nLeucotrienos (LTC₄,LTD₄,LTE₄)\nPGD₂, PAF"]
        O5 --> P3["Activación de factores de transcripción\n(NF-κB, NFAT, AP-1)\n→ síntesis de citocinas\n(TNF, IL-4, IL-5, IL-13, eotaxina)\n(horas)"]
    end

    subgraph Fase_Inmediata ["RESPUESTA INMEDIATA (minutos)"]
        P1 --> Q1["Histamina: vasodilatación,\nedema, broncoconstricción,\nprurito"]
        P2 --> Q2["Leucotrienos: broncoespasmo\nprolongado, moco, permeabilidad\nPGD₂, PAF: inflamación,\nagregación plaquetaria"]
    end

    subgraph Fase_Tardia ["FASE TARDÍA (2-8 horas, persiste días)"]
        P3 --> R1["TNF-α: activa endotelio,\n aumenta VCAM-1, ICAM-1,\n recluta leucocitos"]
        P3 --> R2["IL-4, IL-13: VCAM-1, moco,\n mantienen Th2"]
        P3 --> R3["IL-5: activa eosinófilos"]
        P3 --> R4["Eotaxina: quimiotaxis de eosinófilos"]
        R1 --> S["Reclutamiento masivo de\neosinófilos, neutrófilos, Th2"]
        R2 --> S
        R3 --> S
        R4 --> S
        S --> T["Eosinófilos liberan\nMBP, ECP, EDN, EPO\n→ daño epitelial,\nhiperreactividad bronquial,\nremodelación"]
    end

    subgraph Anafilactoides ["Activación independiente de IgE (anafilactoides)"]
        M -.-> U1["MRGPRX2 (vancomicina,\nopiáceos, contrastes)"]
        M -.-> U2["C3a/C5a (anafilotoxinas)"]
        M -.-> U3["Estímulos físicos (frío,\nejercicio, radiación UV)"]
        U1 --> V["Desgranulación directa\n(sin IgE)"]
        U2 --> V
        U3 --> V
        V --> Q1
        V --> Q2
    end

    subgraph Regulacion ["Regulación negativa"]
        L --> W1["FcγRIIB (ITIM): inhibe señal\n→ recluta SHIP"]
        L --> W2["Células Treg (FoxP3⁺):\nIL-10, TGF-β"]
        L --> W3["IgG4 bloqueante\n(compiten con IgE)"]
    end

    Q1 --> X["MANIFESTACIONES\nCLÍNICAS"]
    Q2 --> X
    T --> X
    X --> Y["Anafilaxia sistémica\nAsma bronquial\nRinitis alérgica\nDermatitis atópica\nUrticaria\nAlergias alimentarias"]